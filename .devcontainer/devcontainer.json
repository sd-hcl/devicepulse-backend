{
  "name": "DevicePulse",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:18",
  "postCreateCommand": "npm install",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "DevicePulse Backend",
      "onAutoForward": "openBrowser"
    }
  },
  "postStartCommand": "npm start"
}
